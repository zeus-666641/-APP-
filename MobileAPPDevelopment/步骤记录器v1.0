<!-- Generated by Trae Work -->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>步骤记录器APP - 产品需求文档</title>
<script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<style>
  :root {
    --bg: #f5f6f8;
    --bg2: #ffffff;
    --ink: #1a1a2e;
    --muted: #6b7280;
    --rule: #e5e7eb;
    --accent: #2563eb;
    --accent2: #7c3aed;
    --accent-light: #eff6ff;
    --success: #10b981;
    --warning: #f59e0b;
    --danger: #ef4444;
  }

  [data-theme="dark"] {
    --bg: #0f172a;
    --bg2: #1e293b;
    --ink: #f1f5f9;
    --muted: #94a3b8;
    --rule: #334155;
    --accent: #3b82f6;
    --accent2: #8b5cf6;
    --accent-light: #1e3a5f;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.7;
    font-size: 15px;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 24px;
  }

  /* Header */
  .report-header {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: white;
    padding: 60px 40px;
    border-radius: 16px;
    margin-bottom: 40px;
    position: relative;
    overflow: hidden;
  }

  .report-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
  }

  .report-header h1 {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 12px;
    position: relative;
    z-index: 1;
  }

  .report-header .subtitle {
    font-size: 16px;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }

  .report-header .meta {
    margin-top: 24px;
    display: flex;
    gap: 24px;
    font-size: 13px;
    opacity: 0.85;
    position: relative;
    z-index: 1;
  }

  /* Theme toggle */
  .theme-toggle {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 100;
    background: var(--bg2);
    border: 1px solid var(--rule);
    border-radius: 20px;
    padding: 8px 16px;
    cursor: pointer;
    font-size: 13px;
    color: var(--ink);
    transition: all 0.3s;
  }

  .theme-toggle:hover {
    border-color: var(--accent);
  }

  /* Navigation */
  .toc {
    background: var(--bg2);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 40px;
    border: 1px solid var(--rule);
  }

  .toc h2 {
    font-size: 16px;
    margin-bottom: 16px;
    color: var(--accent);
  }

  .toc ol {
    padding-left: 20px;
    columns: 2;
    column-gap: 32px;
  }

  .toc li {
    margin-bottom: 8px;
    font-size: 14px;
  }

  .toc a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .toc a:hover {
    color: var(--accent);
  }

  /* Sections */
  section {
    margin-bottom: 48px;
  }

  h2 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--accent);
    color: var(--ink);
  }

  h3 {
    font-size: 18px;
    font-weight: 600;
    margin: 24px 0 12px;
    color: var(--ink);
  }

  h4 {
    font-size: 15px;
    font-weight: 600;
    margin: 16px 0 8px;
    color: var(--accent);
  }

  p {
    margin-bottom: 12px;
    color: var(--ink);
  }

  /* Cards */
  .card {
    background: var(--bg2);
    border-radius: 12px;
    padding: 20px;
    border: 1px solid var(--rule);
    margin-bottom: 16px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin: 20px 0;
  }

  .feature-card {
    background: var(--bg2);
    border-radius: 12px;
    padding: 20px;
    border: 1px solid var(--rule);
    transition: all 0.3s;
  }

  .feature-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .feature-card .icon {
    width: 40px;
    height: 40px;
    background: var(--accent-light);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    margin-bottom: 12px;
  }

  .feature-card h4 {
    margin: 0 0 8px;
    font-size: 15px;
  }

  .feature-card p {
    font-size: 13px;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  /* Tables */
  .table-wrap {
    overflow-x: auto;
    overflow-y: auto;
    max-height: 600px;
    margin: 16px 0;
    border-radius: 8px;
    border: 1px solid var(--rule);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  th {
    background: var(--accent-light);
    color: var(--accent);
    font-weight: 600;
    text-align: left;
    padding: 12px 16px;
    position: sticky;
    top: 0;
    white-space: nowrap;
  }

  td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
  }

  tr:last-child td {
    border-bottom: none;
  }

  tr:hover td {
    background: var(--accent-light);
  }

  /* Highlight */
  mark.key {
    background: none;
    color: var(--accent);
    font-weight: 600;
  }

  /* Badge */
  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }

  .badge.new {
    background: #ecfdf5;
    color: var(--success);
  }

  .badge.core {
    background: var(--accent-light);
    color: var(--accent);
  }

  [data-theme="dark"] .badge.new {
    background: rgba(16, 185, 129, 0.2);
  }

  /* Demo phone frame */
  .demo-section {
    display: flex;
    gap: 32px;
    align-items: flex-start;
    margin: 24px 0;
  }

  .phone-frame {
    width: 320px;
    flex-shrink: 0;
    background: var(--bg2);
    border-radius: 32px;
    padding: 12px;
    border: 2px solid var(--rule);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }

  .phone-screen {
    background: var(--bg);
    border-radius: 24px;
    min-height: 560px;
    padding: 16px;
    position: relative;
    overflow: hidden;
  }

  .phone-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0 16px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 16px;
  }

  .phone-header .back {
    font-size: 20px;
    cursor: pointer;
    color: var(--ink);
  }

  .phone-header .title {
    font-size: 16px;
    font-weight: 600;
  }

  .phone-header .save {
    color: var(--accent);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
  }

  .demo-desc {
    flex: 1;
  }

  .demo-desc h4 {
    margin-top: 0;
  }

  /* Step items */
  .step-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: var(--bg2);
    border-radius: 10px;
    margin-bottom: 8px;
    border: 1px solid var(--rule);
  }

  .step-num {
    width: 28px;
    height: 28px;
    background: var(--accent);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .step-icon {
    width: 36px;
    height: 36px;
    background: var(--accent-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
    min-width: 0;
  }

  .step-name {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .step-detail {
    font-size: 12px;
    color: var(--muted);
  }

  .step-actions {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .step-actions span {
    font-size: 14px;
    cursor: pointer;
    padding: 4px;
    color: var(--muted);
  }

  .step-actions .delete {
    color: var(--danger);
  }

  /* Add button */
  .add-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px;
    background: var(--accent);
    color: white;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    margin-bottom: 12px;
  }

  /* Section title in phone */
  .section-title {
    font-size: 14px;
    font-weight: 600;
    margin: 16px 0 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Trigger tabs */
  .trigger-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: 12px;
    overflow-x: auto;
  }

  .trigger-tab {
    padding: 8px 14px;
    background: var(--bg2);
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    border: 1px solid var(--rule);
    color: var(--muted);
  }

  .trigger-tab.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  /* Form fields */
  .form-group {
    margin-bottom: 12px;
  }

  .form-label {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .form-input {
    width: 100%;
    padding: 10px 12px;
    background: var(--bg2);
    border: 1px solid var(--rule);
    border-radius: 8px;
    font-size: 13px;
    color: var(--ink);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* Toggle switch */
  .toggle-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid var(--rule);
  }

  .toggle-row:last-child {
    border-bottom: none;
  }

  .toggle-label h5 {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .toggle-label p {
    font-size: 12px;
    color: var(--muted);
    margin: 0;
  }

  .toggle-switch {
    width: 44px;
    height: 24px;
    background: var(--rule);
    border-radius: 12px;
    position: relative;
    cursor: pointer;
    transition: background 0.3s;
  }

  .toggle-switch.on {
    background: var(--accent);
  }

  .toggle-switch::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 20px;
    height: 20px;
    background: white;
    border-radius: 50%;
    transition: transform 0.3s;
  }

  .toggle-switch.on::after {
    transform: translateX(20px);
  }

  /* Stats */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 16px;
  }

  .stat-card {
    background: var(--bg2);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
    border: 1px solid var(--rule);
  }

  .stat-icon {
    width: 32px;
    height: 32px;
    margin: 0 auto 6px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
  }

  .stat-icon.blue { background: rgba(37, 99, 235, 0.15); color: var(--accent); }
  .stat-icon.green { background: rgba(16, 185, 129, 0.15); color: var(--success); }
  .stat-icon.purple { background: rgba(124, 58, 237, 0.15); color: var(--accent2); }

  .stat-num {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
  }

  /* Chart placeholder */
  .chart-card {
    background: var(--bg2);
    border-radius: 10px;
    padding: 12px;
    border: 1px solid var(--rule);
    margin-bottom: 12px;
  }

  .chart-title {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .chart-bars {
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    height: 120px;
    padding: 8px 0;
  }

  .chart-bar {
    width: 24px;
    background: var(--accent);
    border-radius: 4px 4px 0 0;
    position: relative;
    opacity: 0.7;
  }

  .chart-bar.today {
    opacity: 1;
  }

  .chart-bar .bar-val {
    position: absolute;
    top: -18px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: var(--muted);
  }

  .chart-bar .bar-label {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: var(--muted);
    white-space: nowrap;
  }

  /* Ranking */
  .rank-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--rule);
  }

  .rank-item:last-child {
    border-bottom: none;
  }

  .rank-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 600;
    flex-shrink: 0;
    color: white;
  }

  .rank-num.top1 { background: #3b82f6; }
  .rank-num.top2 { background: #60a5fa; }
  .rank-num.top3 { background: #93c5fd; }
  .rank-num.other { background: var(--muted); }

  .rank-name {
    flex: 1;
    font-size: 13px;
    font-weight: 500;
  }

  .rank-count {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
  }

  .rank-bar {
    flex: 1;
    height: 6px;
    background: var(--rule);
    border-radius: 3px;
    margin: 0 8px;
    overflow: hidden;
  }

  .rank-bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
  }

  /* Bottom nav */
  .bottom-nav {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-around;
    padding: 12px 0;
    background: var(--bg2);
    border-top: 1px solid var(--rule);
    border-radius: 0 0 24px 24px;
  }

  .nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    color: var(--muted);
    cursor: pointer;
  }

  .nav-item.active {
    color: var(--accent);
  }

  .nav-item .nav-icon {
    font-size: 18px;
  }

  /* Modal */
  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    border-radius: 24px;
    display: flex;
    align-items: flex-end;
    z-index: 10;
  }

  .modal-content {
    width: 100%;
    background: var(--bg2);
    border-radius: 16px 16px 0 0;
    padding: 16px;
    max-height: 80%;
    overflow-y: auto;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .modal-title {
    font-size: 15px;
    font-weight: 600;
  }

  .modal-close {
    font-size: 18px;
    color: var(--muted);
    cursor: pointer;
  }

  .step-type-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .step-type-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 8px;
    background: var(--bg);
    border-radius: 10px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.2s;
  }

  .step-type-item:hover {
    border-color: var(--accent);
    background: var(--accent-light);
  }

  .step-type-item .type-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .step-type-item .type-name {
    font-size: 11px;
    color: var(--muted);
    text-align: center;
  }

  /* Floating button */
  .fab {
    position: fixed;
    bottom: 80px;
    right: 24px;
    width: 56px;
    height: 56px;
    background: var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.4);
    cursor: pointer;
    z-index: 50;
  }

  /* Note callout */
  .callout {
    background: var(--accent-light);
    border-left: 4px solid var(--accent);
    padding: 16px 20px;
    border-radius: 0 8px 8px 0;
    margin: 16px 0;
    font-size: 14px;
  }

  .callout.note {
    border-left-color: var(--accent);
  }

  .callout.new-feature {
    border-left-color: var(--success);
    background: rgba(16, 185, 129, 0.08);
  }

  .callout strong {
    display: block;
    margin-bottom: 4px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container { padding: 20px 16px; }
    .report-header { padding: 40px 24px; }
    .report-header h1 { font-size: 24px; }
    .toc ol { columns: 1; }
    .demo-section { flex-direction: column; }
    .phone-frame { width: 100%; max-width: 320px; margin: 0 auto; }
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body data-theme="dark">

<button class="theme-toggle" onclick="toggleTheme()">🌙 深色模式</button>

<div class="container">

  <!-- Header -->
  <header class="report-header">
    <h1>步骤记录器 APP 产品需求文档</h1>
    <p class="subtitle">自动化操作执行与智能触发引擎</p>
    <div class="meta">
      <span>版本：v1.0</span>
      <span>平台：Android / iOS</span>
      <span>更新日期：2026-07-20</span>
    </div>
  </header>

  <!-- TOC -->
  <nav class="toc">
    <h2>目录</h2>
    <ol>
      <li><a href="#bg">需求背景与产品定位</a></li>
      <li><a href="#overview">产品概述与核心价值</a></li>
      <li><a href="#tasks">任务管理模块</a></li>
      <li><a href="#steps">步骤编辑器</a></li>
      <li><a href="#step-types">步骤类型大全</a></li>
      <li><a href="#triggers">触发器系统</a></li>
      <li><a href="#conditions">条件触发引擎</a></li>
      <li><a href="#stats">数据统计模块</a></li>
      <li><a href="#logs">执行日志模块</a></li>
      <li><a href="#floating">悬浮窗快捷操作</a></li>
      <li><a href="#settings">系统设置</a></li>
      <li><a href="#ui">UI 设计规范</a></li>
      <li><a href="#architecture">技术架构说明</a></li>
    </ol>
  </nav>

  <!-- 1. 需求背景 -->
  <section id="bg">
    <h2>一、需求背景与产品定位</h2>
    <p>在移动设备日益成为人们生活与工作核心的今天，大量重复性操作消耗着用户的时间与精力。无论是每天早晨的固定流程（调节亮度、打开特定应用、发送消息），还是特定场景下的批量设置切换（进入工作模式、阅读模式、睡眠模式），用户都需要一种能够自动化完成这些步骤的工具。</p>
    <p>步骤记录器 APP 正是为解决这一痛点而生。它允许用户创建自定义的操作任务流，通过可视化的步骤编辑器编排执行序列，并借助丰富的触发器与条件系统实现智能化的自动执行。</p>

    <div class="card-grid">
      <div class="feature-card">
        <div class="icon">⚡</div>
        <h4>效率提升</h4>
        <p>将重复性操作自动化，节省用户每天数十分钟的手动操作时间</p>
      </div>
      <div class="feature-card">
        <div class="icon">🎯</div>
        <h4>精准执行</h4>
        <p>确保每一步操作按预期执行，避免人工操作的疏漏与误差</p>
      </div>
      <div class="feature-card">
        <div class="icon">🧠</div>
        <h4>智能触发</h4>
        <p>基于时间、位置、网络、应用状态等多维度条件自动触发任务</p>
      </div>
      <div class="feature-card">
        <div class="icon">🎨</div>
        <h4>极简设计</h4>
        <p>企业级极简风格，深色模式自适应，专注内容而非视觉干扰</p>
      </div>
    </div>
  </section>

  <!-- 2. 产品概述 -->
  <section id="overview">
    <h2>二、产品概述与核心价值</h2>
    <p>步骤记录器是一款面向效率用户的移动端自动化工具，核心能力包括 <mark class="key">步骤录制与复现</mark>、<mark class="key">系统级控制</mark>、<mark class="key">多维度条件触发</mark> 三大板块。用户可以通过可视化编辑器构建复杂的工作流，设定触发条件，让设备在正确的时间自动执行正确的操作。</p>

    <h3>2.1 核心功能架构</h3>
    <div class="card">
      <figure class="diagram">
        <div class="mermaid">
graph TB
    A[步骤记录器 APP] --> B[任务管理]
    A --> C[步骤编辑]
    A --> D[触发系统]
    A --> E[统计日志]
    A --> F[快捷操作]

    B --> B1[任务创建/编辑]
    B --> B2[任务分组]
    B --> B3[任务启停控制]
    B --> B4[子任务嵌套]

    C --> C1[模拟操作类]
    C --> C2[系统控制类]
    C --> C3[媒体调节类]
    C --> C4[网络连接类]
    C --> C5[显示设置类]
    C --> C6[辅助功能类]

    D --> D1[定时触发]
    D --> D2[间隔触发]
    D --> D3[随机间隔触发]
    D --> D4[手动触发]
    D --> D5[条件触发]

    E --> E1[执行统计]
    E --> E2[成功率分析]
    E --> E3[趋势图表]
    E --> E4[执行排行榜]
    E --> E5[详细日志]

    F --> F1[悬浮窗操作]
    F --> F2[快捷启停]
    F --> F3[屏幕常亮]
        </div>
        <figcaption>图 1：产品功能架构图</figcaption>
      </figure>
    </div>

    <h3>2.2 底部导航结构</h3>
    <p>APP 采用三栏式底部导航，分别为 <mark class="key">任务</mark>、<mark class="key">日志</mark>、<mark class="key">统计</mark>。用户可在三个主页面间自由切换，分别对应任务管理、执行记录和数据分析三大核心场景。</p>
  </section>

  <!-- 3. 任务管理模块 -->
  <section id="tasks">
    <h2>三、任务管理模块</h2>
    <p>任务是步骤记录器的核心组织单位。每个任务包含基本信息、触发器配置和执行步骤三大部分。用户可以创建、编辑、删除任务，并控制任务的启用/停用状态。</p>

    <h3>3.1 任务基本信息</h3>
    <div class="demo-section">
      <div class="phone-frame">
        <div class="phone-screen">
          <div class="phone-header">
            <span class="back">←</span>
            <span class="title">编辑任务</span>
            <span class="save">保存</span>
          </div>

          <div class="section-title">基本信息</div>

          <div class="form-group">
            <div class="form-label">任务名称</div>
            <div class="form-input">早安工作流</div>
          </div>

          <div class="form-group">
            <div class="form-label">描述</div>
            <div class="form-input" style="min-height: 80px;">每天早上自动执行的工作流程</div>
          </div>
        </div>
      </div>

      <div class="demo-desc">
        <h4>基本信息字段</h4>
        <p><strong>任务名称</strong>：用户为任务设定的名称，用于在任务列表中识别和区分不同任务。建议命名清晰反映任务用途，如"早安工作流""阅读模式""睡前流程"等。</p>
        <p><strong>任务描述</strong>：对任务用途和执行内容的补充说明，为可选字段。帮助用户在多个相似任务间快速区分，也为后续维护提供参考。</p>

        <h4>交互说明</h4>
        <ul style="padding-left: 20px; font-size: 14px; color: var(--muted);">
          <li style="margin-bottom: 6px;">顶部返回按钮点击后返回任务列表，如有未保存更改需弹窗确认</li>
          <li style="margin-bottom: 6px;">保存按钮在有内容修改时高亮，点击后保存并返回列表</li>
          <li>任务名称为必填项，为空时保存按钮置灰不可点击</li>
        </ul>
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <tr>
          <th>字段名</th>
          <th>类型</th>
          <th>必填</th>
          <th>长度限制</th>
          <th>说明</th>
        </tr>
        <tr>
          <td>任务名称</td>
          <td>文本</td>
          <td>是</td>
          <td>2-30 字符</td>
          <td>任务的唯一标识名称，列表中展示</td>
        </tr>
        <tr>
          <td>任务描述</td>
          <td>长文本</td>
          <td>否</td>
          <td>最多 200 字符</td>
          <td>任务的补充说明信息</td>
        </tr>
        <tr>
          <td>任务图标</td>
          <td>图标选择</td>
          <td>否</td>
          <td>-</td>
          <td>从预设图标库中选择，默认使用通用图标 <span class="badge new">新增</span></td>
        </tr>
        <tr>
          <td>任务分组</td>
          <td>分类选择</td>
          <td>否</td>
          <td>-</td>
          <td>可将任务归类到不同分组便于管理 <span class="badge new">新增</span></td>
        </tr>
        <tr>
          <td>启用状态</td>
          <td>开关</td>
          <td>是</td>
          <td>-</td>
          <td>控制任务是否处于激活状态，关闭后触发器不生效</td>
        </tr>
      </table>
    </div>

    <h3>3.2 任务列表</h3>
    <p>任务列表页为 APP 首页，展示所有已创建的任务。每个任务卡片显示任务名称、简要描述、启用状态开关和最近执行时间。用户可在此页面快速启停任务、进入编辑，或通过右上角按钮创建新任务。</p>

    <div class="callout new-feature">
      <strong>💡 图片补充功能</strong>
      从您提供的设计图中，我识别出任务支持子任务嵌套调用（执行子任务 · 任务ID: 2），这意味着任务之间可以形成层级调用关系，支持构建更复杂的自动化工作流。
    </div>
  </section>

  <!-- 4. 步骤编辑器 -->
  <section id="steps">
    <h2>四、步骤编辑器</h2>
    <p>步骤编辑器是任务的核心配置区域，用户在此添加、排列、编辑和删除执行步骤。每个步骤按顺序依次执行，形成完整的自动化流程。</p>

    <div class="demo-section">
      <div class="phone-frame">
        <div class="phone-screen">
          <div class="phone-header">
            <span class="back">←</span>
            <span class="title">编辑任务</span>
            <span class="save">保存</span>
          </div>

          <div class="section-title">
            <span>执行步骤</span>
            <span class="add-btn" style="margin:0; padding:6px 12px; font-size:12px;">+ 添加步骤</span>
          </div>

          <div class="step-item">
            <div class="step-num">1</div>
            <div class="step-icon">🔔</div>
            <div class="step-content">
              <div class="step-name">发送通知</div>
              <div class="step-detail">标题: 早上好</div>
            </div>
            <div class="step-actions">
              <span>↕</span>
              <span>∨</span>
              <span class="delete">🗑</span>
            </div>
          </div>

          <div class="step-item">
            <div class="step-num">2</div>
            <div class="step-icon">☀️</div>
            <div class="step-content">
              <div class="step-name">调节亮度</div>
              <div class="step-detail">亮度: 80%</div>
            </div>
            <div class="step-actions">
              <span>↕</span>
              <span>∨</span>
              <span class="delete">🗑</span>
            </div>
          </div>

          <div class="step-item">
            <div class="step-num">3</div>
            <div class="step-icon">⏱️</div>
            <div class="step-content">
              <div class="step-name">延时等待</div>
              <div class="step-detail">30秒</div>
            </div>
            <div class="step-actions">
              <span>↕</span>
              <span>∨</span>
              <span class="delete">🗑</span>
            </div>
          </div>

          <div class="step-item">
            <div class="step-num">4</div>
            <div class="step-icon">📷</div>
            <div class="step-content">
              <div class="step-name">屏幕内容识别</div>
              <div class="step-detail">匹配阈值: 85%</div>
            </div>
            <div class="step-actions">
              <span>↕</span>
              <span>∨</span>
              <span class="delete">🗑</span>
            </div>
          </div>

          <div class="step-item">
            <div class="step-num">5</div>
            <div class="step-icon">🔀</div>
            <div class="step-content">
              <div class="step-name">执行子任务</div>
              <div class="step-detail">任务ID: 2</div>
            </div>
            <div class="step-actions">
              <span>↕</span>
              <span>∨</span>
              <span class="delete">🗑</span>
            </div>
          </div>
        </div>
      </div>

      <div class="demo-desc">
        <h4>步骤列表结构</h4>
        <p>每个步骤项包含以下元素，从左到右依次排列：</p>
        <ol style="padding-left: 20px; font-size: 14px;">
          <li style="margin-bottom: 6px;"><strong>步骤序号</strong>：蓝色圆形背景的数字，表示执行顺序</li>
          <li style="margin-bottom: 6px;"><strong>步骤图标</strong>：直观展示步骤类型的图标</li>
          <li style="margin-bottom: 6px;"><strong>步骤名称与详情</strong>：主标题为步骤类型，副标题为具体参数</li>
          <li><strong>操作按钮</strong>：排序（上下拖动）、展开/收起详情、删除</li>
        </ol>

        <h4>核心交互</h4>
        <ul style="padding-left: 20px; font-size: 14px; color: var(--muted);">
          <li style="margin-bottom: 6px;">点击"+ 添加步骤"按钮弹出步骤类型选择面板</li>
          <li style="margin-bottom: 6px;">长按步骤项可进入拖拽排序模式</li>
          <li style="margin-bottom: 6px;">点击步骤项可展开/收起详细参数配置</li>
          <li>删除按钮点击后需二次确认，防止误操作</li>
        </ul>
      </div>
    </div>

    <h3>4.1 添加步骤弹窗</h3>
